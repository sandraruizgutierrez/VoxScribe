{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/dist/server.cjs"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/index.html",
      "methods": ["GET", "HEAD"]
    },
    {
      "src": "/(.*)",
      "dest": "/dist/server.cjs"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
